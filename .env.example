# Copy to .env and fill in real values.
# LITELLM_MASTER_KEY: generate with `openssl rand -hex 32` and prefix with sk-local-
# LEMONADE_HOST_IP: LAN IP of the lemonade-server host. Consumed by
#   docker-compose.yml (extra_hosts) and config/config.yaml (api_base).
#   Override when retargeting the stack to a different LAN host.
# All other keys have sane local defaults — override only if needed.

LITELLM_MASTER_KEY=sk-local-CHANGEME-32-bytes-hex

LEMONADE_HOST_IP=192.168.31.246

REDIS_URL=redis://redis:6379
MILVUS_URI=http://milvus:19530
MILVUS_COLLECTION=litellm_rag
CACHE_SIMILARITY_THRESHOLD=0.8
CACHE_TTL=600

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# OpenAI-compatible client credentials (used by litellm's eager cache embed
# probe). lemonade ignores the key but the openai-compat client requires it.
# OPENAI_API_BASE is interpolated from LEMONADE_HOST_IP at compose time.
OPENAI_API_KEY=dummy-not-used
OPENAI_API_BASE=http://${LEMONADE_HOST_IP:-192.168.31.246}:13305/v1

# Grafana admin password (loopback only — used by /run/secrets/grafana_admin_password)
# Generate with: openssl rand -hex 16
# The actual password is stored in monitoring/secrets/grafana_admin_password (gitignored).
GRAFANA_ADMIN_PASSWORD=changeme-32-bytes-hex

# Prometheus scrape auth for MinIO (basic auth via mc/console creds).
# Litellm /metrics auth uses LITELLM_MASTER_KEY directly — no separate token.
MINIO_METRICS_USER=minioadmin
MINIO_METRICS_PASS=changeme
